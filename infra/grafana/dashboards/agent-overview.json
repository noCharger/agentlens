{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "Total Agent Runs",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 0 },
      "targets": [
        { "expr": "sum(traces_span_metrics_calls_total{span_name=\"LangGraph\"})", "legendFormat": "Total Runs" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "blue", "value": null }] } } }
    },
    {
      "title": "Agent Success Rate",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 0 },
      "targets": [
        { "expr": "sum(traces_span_metrics_calls_total{span_name=\"LangGraph\", status_code=\"STATUS_CODE_OK\"}) / sum(traces_span_metrics_calls_total{span_name=\"LangGraph\"}) * 100", "legendFormat": "Success %" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "red", "value": null }, { "color": "yellow", "value": 50 }, { "color": "green", "value": 80 }] } } }
    },
    {
      "title": "Total Tool Calls",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 0 },
      "targets": [
        { "expr": "sum(traces_span_metrics_calls_total{tool_name!=\"\"})", "legendFormat": "Tool Calls" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "purple", "value": null }] } } }
    },
    {
      "title": "Total LLM Calls",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 0 },
      "targets": [
        { "expr": "sum(traces_span_metrics_calls_total{span_name=\"ChatGoogleGenerativeAI\"})", "legendFormat": "LLM Calls" }
      ],
      "fieldConfig": { "defaults": { "color": { "mode": "thresholds" }, "thresholds": { "steps": [{ "color": "green", "value": null }] } } }
    },
    {
      "title": "LLM Latency (ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "histogram_quantile(0.5, sum(rate(traces_span_metrics_duration_milliseconds_bucket{span_name=\"ChatGoogleGenerativeAI\"}[10m])) by (le))", "legendFormat": "LLM p50" },
        { "expr": "histogram_quantile(0.95, sum(rate(traces_span_metrics_duration_milliseconds_bucket{span_name=\"ChatGoogleGenerativeAI\"}[10m])) by (le))", "legendFormat": "LLM p95" },
        { "expr": "histogram_quantile(0.5, sum(rate(traces_span_metrics_duration_milliseconds_bucket{span_name=\"LangGraph\"}[10m])) by (le))", "legendFormat": "Agent p50" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms" } }
    },
    {
      "title": "Calls by Operation",
      "type": "barchart",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "sum by (span_name) (traces_span_metrics_calls_total{service_name=\"agentlens-eval\"})", "legendFormat": "{{span_name}}" }
      ]
    },
    {
      "title": "Span Rate Over Time",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "targets": [
        { "expr": "sum(rate(traces_span_metrics_calls_total{service_name=\"agentlens-eval\"}[10m])) by (span_name)", "legendFormat": "{{span_name}}" }
      ]
    },
    {
      "title": "Recent Traces",
      "type": "table",
      "datasource": { "type": "tempo", "uid": "tempo" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        { "queryType": "search", "limit": 20, "filters": [{ "id": "service-name", "tag": "service.name", "operator": "=", "value": ["agentlens-eval"] }] }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["agentlens", "llm", "agent"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "AgentLens - Agent Overview",
  "uid": "agentlens-overview"
}
