# Get your free API key from https://aistudio.google.com/app/apikey (no credit card required)
GOOGLE_API_KEY=your-api-key-here

# Model configuration (free tier daily limits)
AGENT_MODEL=gemini-2.5-flash          # 20 req/day
JUDGE_MODEL=gemini-2.5-flash-lite     # 1000 req/day

# OTEL configuration (requires: docker compose up)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agentlens

# Grafana (http://localhost:3001)
GF_SECURITY_ADMIN_PASSWORD=admin
