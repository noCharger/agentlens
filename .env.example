# API keys and endpoints by provider
# Gemini (Google AI Studio, no credit card required)
GOOGLE_API_KEY=your-api-key-here

# DeepSeek
DEEPSEEK_API_KEY=your-deepseek-api-key
DEEPSEEK_API_BASE=https://api.deepseek.com

# OpenRouter
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_API_BASE=https://openrouter.ai/api/v1
OPENROUTER_HTTP_REFERER=
OPENROUTER_X_TITLE=

# Zhipu (BigModel / GLM)
ZHIPU_API_KEY=your-zhipu-api-key
ZHIPU_API_BASE=https://open.bigmodel.cn/api/paas/v4

# Model configuration
AGENT_FRAMEWORK=langgraph
AGENT_MODEL=gemini:gemini-2.5-flash
JUDGE_MODEL=gemini:gemini-2.5-flash-lite
AGENT_MAX_TOKENS=2048
JUDGE_MAX_TOKENS=512

# Model examples by provider:
# Gemini:
# AGENT_MODEL=gemini:gemini-2.5-flash
# JUDGE_MODEL=gemini:gemini-2.5-flash-lite
# DeepSeek:
# AGENT_MODEL=deepseek:deepseek-chat
# JUDGE_MODEL=deepseek:deepseek-chat
# OpenRouter:
# AGENT_MODEL=openrouter:openai/gpt-4o-mini
# JUDGE_MODEL=openrouter:openai/gpt-4o-mini
# Zhipu:
# AGENT_MODEL=zhipu:glm-4-plus
# JUDGE_MODEL=zhipu:glm-4-plus
# Mixed:
# AGENT_MODEL=deepseek:deepseek-chat
# JUDGE_MODEL=openrouter:openai/gpt-4o-mini

# Agent runtime framework:
# AGENT_FRAMEWORK=langgraph
# AGENT_FRAMEWORK=ag2

# OTEL configuration (requires: docker compose up)
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=agentlens

# Grafana (http://localhost:3001)
GF_SECURITY_ADMIN_PASSWORD=admin
